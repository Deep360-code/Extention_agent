{
  "manifest_version": 3,
  "name": "Agentic AI Assistant",
  "version": "1.0",
  "description": "An intelligent browser assistant with multi-step reasoning.",
  "permissions": [
    "activeTab",
    "storage",
    "scripting"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ]
    }
  ],
  "host_permissions": [
    "http://localhost:8000/*"
  ]
}